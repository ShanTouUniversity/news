---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import NewsCard from '../../../../components/NewsCard.astro';
import Pagination from '../../../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../../i18n/translations';

export const prerender = true;

const lang = 'zh';
const prefix = 'zh/';

export async function getStaticPaths() {
  const pageSize = 24;
  const categoryToSlugZh: Record<string, string> = {
    '校园新闻': 'campus',
    '校园动态': 'campus',
    '通知公告': 'notices',
    '学术科研': 'academic',
    '学生活动': 'student',
    '人物风采': 'profiles',
    '媒体聚焦': 'media',
    '就业招聘': 'jobs',
  };
  const allNews = await getCollection('news', ({ data, id }) => !data.draft && id.startsWith('zh/'));
  const categories = [...new Set(allNews.map((n) => n.data.category))];
  const targets = [
    { slug: 'all', category: '全部资讯', posts: allNews },
    ...categories.map((category) => ({
      slug: categoryToSlugZh[category] || category.toLowerCase().replace(/\s+/g, '-'),
      category,
      posts: allNews.filter((post) => post.data.category === category),
    })),
  ];

  return targets.flatMap(({ slug, category, posts }) => {
    const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
    const lastPage = Math.max(1, Math.ceil(sorted.length / pageSize));

    return Array.from({ length: Math.max(0, lastPage - 1) }, (_, index) => {
      const currentPage = index + 2;
      const start = (currentPage - 1) * pageSize;

      return {
        params: { category: slug, page: String(currentPage) },
        props: {
          category,
          currentPage,
          lastPage,
          pageNews: sorted.slice(start, start + pageSize),
        },
      };
    });
  });
}

const { category, currentPage, lastPage, pageNews } = Astro.props;
---

<BaseLayout title={`${category} - ${currentPage}`} description={`${category} - 汕大资讯非官方平台，浏览汕头大学${category}相关报道`} lang={lang}>
  <section class="mb-8">
    <nav class="text-sm text-gray-400 dark:text-gray-500 mb-4">
      <a href="/" class="hover:text-stu-gold">{t(lang, 'home')}</a>
      <span class="mx-2">/</span>
      <a href={`/news/${Astro.params.category}/`} class="hover:text-stu-gold">{category}</a>
      <span class="mx-2">/</span>
      <span>第 {currentPage} 页</span>
    </nav>
    <h1 class="text-3xl font-bold text-stu-dark dark:text-gray-100">{category}</h1>
  </section>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {pageNews.map((post) => (
      <NewsCard
        title={post.data.title}
        href={`/news/${post.id.replace(prefix, '')}/`}
        pubDate={post.data.pubDate}
        description={post.data.description}
        heroImage={post.data.heroImage}
        category={post.data.category}
        lang={lang}
      />
    ))}
  </div>

  <Pagination
    currentPage={currentPage}
    lastPage={lastPage}
    basePath={`/news/${Astro.params.category}/`}
    labels={{ previous: '上一页', next: '下一页', page: '第', of: '页 / 共' }}
  />
</BaseLayout>
