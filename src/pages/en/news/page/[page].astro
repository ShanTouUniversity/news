---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import NewsCard from '../../../../components/NewsCard.astro';
import Pagination from '../../../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../../i18n/translations';

export const prerender = true;

const lang = 'en';
const prefix = 'en/';

export async function getStaticPaths() {
  const pageSize = 24;
  const allNews = await getCollection('news', ({ data, id }) => !data.draft && id.startsWith('en/'));
  const sortedNews = allNews.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  const lastPage = Math.max(1, Math.ceil(sortedNews.length / pageSize));

  return Array.from({ length: Math.max(0, lastPage - 1) }, (_, index) => {
    const currentPage = index + 2;
    const start = (currentPage - 1) * pageSize;

    return {
      params: { page: String(currentPage) },
      props: {
        currentPage,
        lastPage,
        pageNews: sortedNews.slice(start, start + pageSize),
      },
    };
  });
}

const { currentPage, lastPage, pageNews } = Astro.props;
---

<BaseLayout title={`${t(lang, 'allNews')} - ${currentPage}`} description={t(lang, 'siteDescription')} lang={lang}>
  <section class="mb-8">
    <nav class="text-sm text-gray-400 dark:text-gray-500 mb-4">
      <a href="/en/" class="hover:text-stu-gold">{t(lang, 'home')}</a>
      <span class="mx-2">/</span>
      <a href="/en/news/" class="hover:text-stu-gold">{t(lang, 'allNews')}</a>
      <span class="mx-2">/</span>
      <span>Page {currentPage}</span>
    </nav>
    <h1 class="text-3xl font-bold text-stu-dark dark:text-gray-100">{t(lang, 'allNews')}</h1>
  </section>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {pageNews.map((post) => (
      <NewsCard
        title={post.data.title}
        href={`/en/news/${post.id.replace(prefix, '')}/`}
        pubDate={post.data.pubDate}
        description={post.data.description}
        heroImage={post.data.heroImage}
        category={post.data.category}
        lang={lang}
      />
    ))}
  </div>

  <Pagination
    currentPage={currentPage}
    lastPage={lastPage}
    basePath="/en/news/"
    labels={{ previous: 'Previous', next: 'Next', page: 'Page', of: 'of' }}
  />
</BaseLayout>
