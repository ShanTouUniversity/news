---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsCard from '../../../components/NewsCard.astro';
import Pagination from '../../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/translations';
import { NEWS_PAGE_SIZE } from '../../../lib/newsPagination.mjs';

const lang = 'en';
const prefix = 'en/';

const allNews = await getCollection('news', ({ data, id }) => !data.draft && id.startsWith(prefix));
const sortedNews = allNews.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const currentPage = 1;
const lastPage = Math.max(1, Math.ceil(sortedNews.length / NEWS_PAGE_SIZE));
const pageNews = sortedNews.slice(0, NEWS_PAGE_SIZE);
---

<BaseLayout title={t(lang, 'allNews')} description={t(lang, 'siteDescription')} lang={lang}>
  <section class="mb-8">
    <nav class="text-sm text-gray-400 dark:text-gray-500 mb-4">
      <a href="/en/" class="hover:text-stu-gold">{t(lang, 'home')}</a>
      <span class="mx-2">/</span>
      <span>{t(lang, 'allNews')}</span>
    </nav>
    <h1 class="text-3xl font-bold text-stu-dark dark:text-gray-100">{t(lang, 'allNews')}</h1>
  </section>

  {pageNews.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {pageNews.map((post) => (
        <NewsCard
          title={post.data.title}
          href={`/en/news/${post.id.replace(prefix, '')}/`}
          pubDate={post.data.pubDate}
          description={post.data.description}
          heroImage={post.data.heroImage}
          category={post.data.category}
          lang={lang}
        />
      ))}
    </div>
  ) : (
    <div class="text-center py-20 text-gray-400">
      <p class="text-xl">{t(lang, 'noNews')}</p>
      <a href="/en/" class="mt-4 inline-block text-stu-gold-dark hover:text-stu-gold">{t(lang, 'backToHome')} &rarr;</a>
    </div>
  )}

  <Pagination
    currentPage={currentPage}
    lastPage={lastPage}
    basePath="/en/news/"
    labels={{ previous: 'Previous', next: 'Next', page: 'Page', of: 'of' }}
  />
</BaseLayout>
