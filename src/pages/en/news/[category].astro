---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsCard from '../../../components/NewsCard.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/translations';
import { getCategorySlug } from '../../../i18n/utils';

export const prerender = true;

const lang = 'en';
const prefix = 'en/';

const slugToCategoryEn: Record<string, string> = {
  campus: 'Campus News',
  academic: 'Academic',
  student: 'Student Life',
  media: 'Media',
  jobs: 'Jobs & Career',
};

export async function getStaticPaths() {
  const allNews = await getCollection('news', ({ data, id }) => !data.draft && id.startsWith('en/'));
  const categories = [...new Set(allNews.map((n) => n.data.category))];

  const slugsEn: Record<string, string> = {
    'Campus News': 'campus',
    'Campus': 'campus',
    'Academic': 'academic',
    'Student Life': 'student',
    'Media': 'media',
    'Jobs & Career': 'jobs',
  };

  const paths = categories.map((cat) => ({
    params: { category: slugsEn[cat] || cat.toLowerCase().replace(/\s+/g, '-') },
    props: { category: cat },
  }));

  paths.push({ params: { category: 'all' }, props: { category: 'All News' } });

  return paths;
}

const { category } = Astro.props;
const isAll = category === 'All News';

const allNews = await getCollection('news', ({ data, id }) => !data.draft && id.startsWith(prefix));
const filtered = isAll
  ? allNews
  : allNews.filter((n) => n.data.category === category || slugToCategoryEn[Astro.params.category!] === n.data.category);
const sorted = filtered.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title={category} description={`${category} - STU News unofficial platform, browse Shantou University ${category} coverage`} lang={lang}>
  <section class="mb-8">
    <nav class="text-sm text-gray-400 dark:text-gray-500 mb-4">
      <a href="/en/" class="hover:text-stu-gold">{t(lang, 'home')}</a>
      <span class="mx-2">/</span>
      <span>{category}</span>
    </nav>
    <h1 class="text-3xl font-bold text-stu-dark dark:text-gray-100">{category}</h1>
  </section>

  {sorted.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sorted.map((post) => (
        <NewsCard
          title={post.data.title}
          href={`/en/news/${post.id.replace(prefix, '')}/`}
          pubDate={post.data.pubDate}
          description={post.data.description}
          heroImage={post.data.heroImage}
          category={post.data.category}
          lang={lang}
        />
      ))}
    </div>
  ) : (
    <div class="text-center py-20 text-gray-400">
      <p class="text-xl">{t(lang, 'noCategoryNews')}</p>
      <a href="/en/" class="mt-4 inline-block text-stu-gold-dark hover:text-stu-gold">{t(lang, 'backToHome')} &rarr;</a>
    </div>
  )}
</BaseLayout>
