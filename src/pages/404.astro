---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n/translations';

export const prerender = true;

const lang = 'zh';
---

<BaseLayout title={t(lang, 'pageNotFound')} description="404" lang={lang}>
  <div class="text-center py-20">
    <div class="text-8xl font-bold text-stu-gold/20 mb-4">404</div>
    <h1 class="text-2xl font-bold text-stu-dark dark:text-gray-100 mb-4">{t(lang, 'pageNotFound')}</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-8">{t(lang, 'pageNotFoundDesc')}</p>
    <a href="/" class="inline-block px-6 py-3 bg-stu-gold text-white rounded-lg hover:bg-stu-gold-dark transition-colors">
      {t(lang, 'backToHome')}
    </a>
  </div>
</BaseLayout>
