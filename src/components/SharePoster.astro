---
interface Props {
  title: string;
  description: string;
  category: string;
  author: string;
  date: string;
  url: string;
  siteName: string;
  lang: string;
  shareLabel: string;
  scanToRead: string;
  downloadLabel: string;
}

const { title, description, category, author, date, url, siteName, lang, shareLabel, scanToRead, downloadLabel } = Astro.props;
---

<div id="share-poster-wrapper">
  <button
    id="share-btn"
    class="inline-flex items-center gap-2 px-4 py-2 bg-stu-gold/10 text-stu-gold hover:bg-stu-gold/20 rounded-lg transition-colors text-sm font-medium"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
    </svg>
    {shareLabel}
  </button>

  <div id="share-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 backdrop-blur-sm">
    <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-2xl p-6 max-w-md w-full mx-4 relative">
      <button id="share-modal-close" class="absolute top-3 right-3 p-1 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div id="poster-container" class="overflow-hidden rounded-xl mb-4">
        <div id="poster-card" data-url={url}
          class="relative w-full bg-gradient-to-br from-[#FDF8F3] to-[#F5EDE3] p-6 flex flex-col"
          style="aspect-ratio: 3/4; font-family: system-ui, -apple-system, sans-serif;"
        >
          <div class="flex items-center gap-3 mb-5">
            <img src="/logo.webp" alt="logo" class="w-10 h-10 rounded-lg" />
            <div>
              <div class="text-[#2C2420] font-bold text-sm">{siteName}</div>
              <div class="text-[#AC7D51] text-xs">Shantou University News</div>
            </div>
          </div>

          <span class="inline-block self-start px-2.5 py-1 bg-[#AC7D51]/10 text-[#AC7D51] text-xs font-medium rounded mb-3">
            {category}
          </span>

          <h2 class="text-[#2C2420] font-bold text-lg leading-snug mb-2" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">
            {title}
          </h2>

          <p class="text-[#8B6540] text-xs leading-relaxed mb-auto" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">
            {description}
          </p>

          <div class="text-[#8B6540] text-xs mt-3">
            {author} · {date}
          </div>

          <div class="flex items-center gap-4 mt-5 pt-4 border-t border-[#AC7D51]/20">
            <img id="poster-qrcode" alt="QR Code" class="w-24 h-24 rounded-lg bg-white p-1 shrink-0" />
            <div class="flex flex-col justify-center">
              <span class="text-[#2C2420] text-sm font-medium">{scanToRead}</span>
              <span class="text-[#8B6540] text-xs mt-1">news.shantou.university</span>
            </div>
          </div>
        </div>
      </div>

      <div class="flex gap-3">
        <button id="poster-download" class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 bg-[#AC7D51] text-white rounded-lg hover:bg-[#8B6540] transition-colors text-sm font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          {downloadLabel}
        </button>
        <button id="poster-share-native" class="flex-1 hidden items-center justify-center gap-2 px-4 py-2.5 border border-[#AC7D51] text-[#AC7D51] rounded-lg hover:bg-[#AC7D51]/10 transition-colors text-sm font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
          </svg>
          {shareLabel}
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import QRCode from 'qrcode';
  import { domToPng } from 'modern-screenshot';

  function initSharePoster() {
    const wrapper = document.getElementById('share-poster-wrapper');
    const shareBtn = document.getElementById('share-btn');
    const modal = document.getElementById('share-modal');
    const closeBtn = document.getElementById('share-modal-close');
    const downloadBtn = document.getElementById('poster-download');
    const nativeShareBtn = document.getElementById('poster-share-native');
    const qrImg = document.getElementById('poster-qrcode') as HTMLImageElement;
    const posterCard = document.getElementById('poster-card');

    if (!shareBtn || !modal || !posterCard || !qrImg || !wrapper) return;
    if (wrapper.dataset.initialized) return;
    wrapper.dataset.initialized = 'true';

    const url = posterCard.dataset.url || window.location.href;

    if (navigator.share) {
      nativeShareBtn?.classList.remove('hidden');
      nativeShareBtn?.classList.add('flex');
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }

    function onKeydown(e: KeyboardEvent) {
      if (e.key === 'Escape') closeModal();
    }

    shareBtn.addEventListener('click', async () => {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';

      try {
        qrImg.src = await QRCode.toDataURL(url, {
          width: 192,
          margin: 1,
          color: { dark: '#2C2420', light: '#FFFFFF' },
        });
      } catch {}
    });

    closeBtn?.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', onKeydown);

    async function capturePoster(): Promise<Blob> {
      const dataUrl = await domToPng(posterCard!, {
        scale: 2,
        backgroundColor: '#FDF8F3',
      });
      const res = await fetch(dataUrl);
      return await res.blob();
    }

    downloadBtn?.addEventListener('click', async () => {
      if (!posterCard) return;
      downloadBtn.disabled = true;
      try {
        const blob = await capturePoster();
        const link = document.createElement('a');
        link.download = 'stu-news-poster.png';
        link.href = URL.createObjectURL(blob);
        link.click();
        URL.revokeObjectURL(link.href);
      } finally {
        downloadBtn.disabled = false;
      }
    });

    nativeShareBtn?.addEventListener('click', async () => {
      if (!posterCard || !navigator.share) return;
      nativeShareBtn.setAttribute('disabled', 'true');
      try {
        const blob = await capturePoster();
        const file = new File([blob], 'stu-news-poster.png', { type: 'image/png' });
        try {
          await navigator.share({
            title: document.title,
            url: url,
            files: [file],
          });
        } catch {}
      } finally {
        nativeShareBtn.removeAttribute('disabled');
      }
    });
  }

  initSharePoster();
  document.addEventListener('astro:after-swap', initSharePoster);
</script>
