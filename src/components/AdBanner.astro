---
interface Props {
  lang?: string;
  class?: string;
}

const { lang = 'zh', class: className = '' } = Astro.props;
---

<ins class={`adsbygoogle ${className}`}
  style="display:block; text-align:center; max-height:150px; overflow:hidden;"
  data-ad-layout="in-article"
  data-ad-format="fluid"
  data-ad-client="ca-pub-8794078230518228"
  data-ad-slot="9208866673"></ins>
<script is:inline>
  (adsbygoogle = window.adsbygoogle || []).push({});
</script>
