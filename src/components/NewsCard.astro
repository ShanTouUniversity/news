---
interface Props {
  title: string;
  href: string;
  pubDate: Date;
  description?: string;
  heroImage?: string;
  category?: string;
  lang?: string;
  variant?: 'default' | 'featured';
}

const { title, href, pubDate, description, heroImage, category, lang = 'zh', variant = 'default' } = Astro.props;

const dateStr = pubDate.toLocaleDateString(lang === 'en' ? 'en-US' : 'zh-CN', {
  month: 'short',
  day: 'numeric',
});

const categoryColors: Record<string, string> = {
  '校园新闻': 'bg-amber-500',
  '学术科研': 'bg-emerald-600',
  '学生活动': 'bg-sky-500',
  '媒体聚焦': 'bg-rose-500',
  'Campus News': 'bg-amber-500',
  'Academic': 'bg-emerald-600',
  'Student Life': 'bg-sky-500',
  'Media': 'bg-rose-500',
};

const accentColor = categoryColors[category || ''] || 'bg-stu-gold';
---

{variant === 'featured' ? (
  <article class="group relative bg-white dark:bg-stu-dark rounded-2xl border border-stu-gray-dark dark:border-white/10 hover:shadow-xl transition-all duration-300 overflow-hidden">
    <a href={href} class="block md:flex">
      {heroImage ? (
        <div class="md:w-2/5 aspect-video md:aspect-auto overflow-hidden">
          <img src={heroImage} alt={title} loading={variant === 'featured' ? 'eager' : 'lazy'} fetchpriority={variant === 'featured' ? 'high' : undefined} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
        </div>
      ) : (
        <div class="md:w-2/5 aspect-video md:aspect-auto bg-gradient-to-br from-stu-gold/20 via-stu-cream to-stu-gold/10 dark:from-stu-dark-light dark:via-stu-dark dark:to-stu-dark-light flex items-center justify-center relative overflow-hidden">
          <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23AC7D51' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>
          <span class="text-stu-gold/20 text-8xl font-black tracking-tighter select-none">ST.U</span>
        </div>
      )}
      <div class="md:w-3/5 p-6 md:p-8 flex flex-col justify-center">
        {category && (
          <span class={`inline-block self-start px-2.5 py-1 ${accentColor} text-white text-xs font-semibold rounded-full mb-3`}>
            {category}
          </span>
        )}
        <h3 class="text-xl md:text-2xl font-bold text-stu-dark dark:text-gray-100 group-hover:text-stu-gold-dark dark:group-hover:text-stu-gold transition-colors leading-snug mb-3">
          {title}
        </h3>
        {description && (
          <p class="text-gray-500 dark:text-gray-400 line-clamp-2 mb-4">{description}</p>
        )}
        <time class="text-xs text-gray-400 dark:text-gray-500 font-medium">{dateStr}</time>
      </div>
    </a>
  </article>
) : (
  <article class="group relative bg-white dark:bg-stu-dark rounded-xl border border-stu-gray-dark dark:border-white/10 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 overflow-hidden">
    <a href={href} class="block">
      {heroImage ? (
        <div class="aspect-[16/9] overflow-hidden">
          <img src={heroImage} alt={title} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
        </div>
      ) : (
        <div class={`h-1.5 w-full ${accentColor}`}></div>
      )}
      <div class="p-4 pt-3">
        <div class="flex items-center gap-2 mb-2">
          {category && (
            <span class={`inline-block w-1.5 h-1.5 rounded-full ${accentColor}`}></span>
          )}
          {category && (
            <span class="text-xs text-gray-400 dark:text-gray-500 font-medium">{category}</span>
          )}
          <span class="text-xs text-gray-300 dark:text-gray-600 ml-auto">{dateStr}</span>
        </div>
        <h3 class="text-base font-bold text-stu-dark dark:text-gray-100 group-hover:text-stu-gold-dark dark:group-hover:text-stu-gold transition-colors line-clamp-2 leading-snug">
          {title}
        </h3>
        {description && (
          <p class="mt-2 text-sm text-gray-400 dark:text-gray-500 line-clamp-2">{description}</p>
        )}
      </div>
    </a>
  </article>
)}
