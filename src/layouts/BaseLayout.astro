---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdBanner from '../components/AdBanner.astro';
import { getLangFromUrl } from '../i18n/utils';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  modifiedDate?: Date;
  author?: string;
  section?: string;
  tags?: string[];
}

const {
  title,
  description,
  image,
  lang = getLangFromUrl(Astro.url),
  type = 'website',
  publishedDate,
  modifiedDate,
  author,
  section,
  tags,
} = Astro.props;
---

<!doctype html>
<html lang={lang} class="">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      lang={lang}
      type={type}
      publishedDate={publishedDate}
      modifiedDate={modifiedDate}
      author={author}
      section={section}
      tags={tags}
    />
  </head>
  <body class="min-h-screen flex flex-col" data-lang={lang}>
    <Header lang={lang} />
    <main class="flex-1 max-w-7xl mx-auto w-full px-4 py-6">
      <slot />
    </main>
    <AdBanner lang={lang} class="max-w-7xl mx-auto w-full px-4 pb-6" />
    <Footer lang={lang} />

    <div class="cf-turnstile" data-sitekey="0x4AAAAAADTiuHGeQczrr_ga" data-callback="onTurnstileSuccess" data-theme="auto"></div>
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
      function onTurnstileSuccess(token) {
        document.body.setAttribute('data-turnstile', 'passed');
      }
    </script>
  </body>
</html>
