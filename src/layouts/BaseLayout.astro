---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdBanner from '../components/AdBanner.astro';
import { t } from '../i18n/translations';
import { getLangFromUrl } from '../i18n/utils';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: string;
}

const { title, description, image, lang = getLangFromUrl(Astro.url) } = Astro.props;
const dir = lang === 'en' ? 'ltr' : 'ltr';
---

<!doctype html>
<html lang={lang} class="">
  <head>
    <BaseHead title={title} description={description} image={image} lang={lang} />
  </head>
  <body class="min-h-screen flex flex-col" data-lang={lang}>
    <Header lang={lang} />
    <main class="flex-1 max-w-7xl mx-auto w-full px-4 py-6">
      <slot />
    </main>
    <AdBanner lang={lang} class="max-w-7xl mx-auto w-full px-4 pb-6" />
    <Footer lang={lang} />

    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </body>
</html>
